# ShopVN backend environment template
# Copy to .env for local development. Never commit real credentials.

# Application
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://127.0.0.1:8891
BACKEND_URL=http://127.0.0.1:3000
ADMIN_URL=http://127.0.0.1:8891
CORS_ORIGINS=http://127.0.0.1:8891,http://localhost:8891
LOG_LEVEL=info

# PostgreSQL for direct local execution
DATABASE_URL=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=shopvn_db
DB_USER=shopvn_user
DB_PASSWORD=
DB_SSL=false
DB_POOL_MAX=20
DB_POOL_MIN=2
DB_POOL_ACQUIRE=60000
DB_POOL_IDLE=10000
DB_STATEMENT_TIMEOUT=30000
DB_IDLE_TX_TIMEOUT=60000

# PostgreSQL variables used by Docker Compose
POSTGRES_DB=shopvn_db
POSTGRES_USER=shopvn_user
POSTGRES_PASSWORD=

# Database lifecycle
DB_SYNC_ON_STARTUP=false
SEED_ON_STARTUP=false
ENSURE_INVENTORY_ON_STARTUP=false
DB_MIGRATION_LOCK_ID=20260722
DB_BOOTSTRAP_LOCK_ID=20260704

# Authentication. Generate two different random values of at least 32 characters.
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=

# Redis, cache and BullMQ
REDIS_URL=redis://127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CONNECT_TIMEOUT_MS=10000
WORKER_CONCURRENCY=5
QUEUE_JOB_ATTEMPTS=3
QUEUE_JOB_BACKOFF_MS=5000
QUEUE_REMOVE_COMPLETE_AGE_SECONDS=3600
QUEUE_REMOVE_COMPLETE_COUNT=1000
QUEUE_REMOVE_FAIL_AGE_SECONDS=604800
QUEUE_REMOVE_FAIL_COUNT=5000

# Email worker
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# Uploads and optional CDN
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CDN_ENABLED=false
CDN_DOMAIN=

# Request protection
JSON_BODY_LIMIT=2mb
FORM_BODY_LIMIT=2mb
API_RATE_LIMIT_MAX=300
API_RATE_LIMIT_WINDOW_SECONDS=60
MAX_CONCURRENT_REQUESTS=1000
MAX_EVENT_LOOP_LAG_MS=200

# Marketplace webhook authentication
WEBHOOK_SHARED_SECRET=

# Optional provider IP allowlists. Signatures are always verified.
REQUIRE_WEBHOOK_IP_ALLOWLIST=false
VNPAY_ALLOWED_IPS=
ZALOPAY_ALLOWED_IPS=
MOMO_ALLOWED_IPS=
PAYOS_ALLOWED_IPS=

# VNPay sandbox
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://127.0.0.1:3000/api/v1/payment/vnpay/return
VNPAY_IPN_URL=http://127.0.0.1:3000/api/v1/payment/vnpay/ipn

# ZaloPay sandbox
ZALOPAY_APP_ID=
ZALOPAY_KEY1=
ZALOPAY_KEY2=
ZALOPAY_API_URL=https://sb-openapi.zalopay.vn
ZALOPAY_CALLBACK_URL=http://127.0.0.1:3000/api/v1/payment/webhooks/zalopay/callback

# MoMo sandbox
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_API_URL=https://test-payment.momo.vn/v2/gateway/api
MOMO_IPN_URL=http://127.0.0.1:3000/api/v1/payment/webhooks/momo/callback

# PayOS
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_API_URL=https://api-merchant.payos.vn/v2

# GHN shipping (optional)
GHN_API_URL=https://dev-online-gateway.ghn.vn/shiip/public-api
GHN_SHOP_ID=
GHN_TOKEN=
SHOP_NAME=ShopVN
SHOP_PHONE=
SHOP_ADDRESS=
SHOP_WARD_ID=
SHOP_DISTRICT_ID=

# Gemini assistant (optional)
GEMINI_API_KEY=
