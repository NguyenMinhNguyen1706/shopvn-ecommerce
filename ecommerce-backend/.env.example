# ═══════════════════════════════════════════════════════════════════════════════
# E-COMMERCE 2026 - ENVIRONMENT CONFIGURATION
# Phase 1: Foundation (Performance, Payments, Shipping)
# ═══════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────────
# APPLICATION
# ──────────────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3000

# ──────────────────────────────────────────────────────────────────────────────
# DATABASE
# ──────────────────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ecommerce_db
DB_USER=root
DB_PASSWORD=

# ──────────────────────────────────────────────────────────────────────────────
# JWT (Existing)
# ──────────────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# ──────────────────────────────────────────────────────────────────────────────
# CLOUDINARY (Existing - Image Upload)
# ──────────────────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ──────────────────────────────────────────────────────────────────────────────
# ✨ NEW 2026: REDIS CACHING LAYER
# Install: npm install redis
# Setup: brew install redis && redis-server (Mac) or apt-get install redis-server (Linux)
# ──────────────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ──────────────────────────────────────────────────────────────────────────────
# ✨ NEW 2026: ZALOPAY PAYMENT
# Get from: https://business.zalopay.vn/
# Docs: https://docs.zalopay.vn/
# ──────────────────────────────────────────────────────────────────────────────
ZALOPAY_APP_ID=2553
ZALOPAY_KEY1=PcY4gVvWkMMaGv30IW9Lj1j6fqXWHcPl8Z7DQc8
ZALOPAY_KEY2=trMrHm9yEMi+OMaVHUyvESUYS2SJ59ye1xK2EV06IYE=
ZALOPAY_API_URL=https://sandbox.zalopay.com.vn/api/v2

# ──────────────────────────────────────────────────────────────────────────────
# ✨ NEW 2026: MOMO PAYMENT
# Get from: https://business.momo.vn/
# Docs: https://developers.momo.vn/
# ──────────────────────────────────────────────────────────────────────────────
MOMO_PARTNER_CODE=MOMOXXXXXX
MOMO_ACCESS_KEY=F8BF47244BC0DF28
MOMO_SECRET_KEY=K951B6PE1waDMi640xQtYiCLFISreF57
