# ──────────────────────────────────────────────────────────────────────────────
# ✨ NEW 2026: PAYOS - VIETQR BANK TRANSFER (AUTO-RECONCILIATION)
# Get from: https://payos.vn/
# Features: Automatic payment reconciliation (zero-touch, 1-3 seconds)
# ──────────────────────────────────────────────────────────────────────────────
PAYOS_CLIENT_ID=your_client_id
PAYOS_API_KEY=your_api_key
PAYOS_CHECKSUM_KEY=your_checksum_key
PAYOS_API_URL=https://api.payos.vn/v1

# ──────────────────────────────────────────────────────────────────────────────
# ✨ NEW 2026: GHN SHIPPING (Giao Hàng Nhanh)
# Get from: https://shiip.ghn.vn/
# Features: Real-time shipping calculation, tracking sync
# Coverage: Vietnam-wide (2-3 day standard delivery)
# ──────────────────────────────────────────────────────────────────────────────
GHN_API_URL=https://dev-online-gateway.ghn.vn/shiip/public-api
GHN_SHOP_ID=123456
GHN_TOKEN=your_ghn_auth_token
GHN_WEBHOOK_URL=http://localhost:3000/api/shipping/webhooks/ghn

# Your warehouse location (required for GHN)
SHOP_NAME=E-Commerce Store 2026
SHOP_PHONE=0123456789
SHOP_ADDRESS=123 Tran Hung Dao Street, Hoan Kiem, Ha Noi
SHOP_WARD_ID=1
SHOP_DISTRICT_ID=1

# ──────────────────────────────────────────────────────────────────────────────
# VNPAY (Existing)
# ──────────────────────────────────────────────────────────────────────────────
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paygate/pay.html
VNPAY_RETURN_URL=http://localhost:3000/api/payment/vnpay/return
VNPAY_IPN_URL=http://localhost:3000/api/payment/vnpay/ipn

# ──────────────────────────────────────────────────────────────────────────────
# OPTIONAL: Google Gemini AI (Phase 3)
# ──────────────────────────────────────────────────────────────────────────────
GOOGLE_GEMINI_API_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# OPTIONAL: SendGrid Email (Phase 3)
# ──────────────────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ──────────────────────────────────────────────────────────────────────────────
# SETUP INSTRUCTIONS:
# 1. Copy this to .env: cp .env.example .env
# 2. Fill in your credentials
# 3. For development: Use SANDBOX credentials (test mode)
# 4. Test all APIs before deploying to production
# 5. Add .env to .gitignore (never commit credentials)
# ──────────────────────────────────────────────────────────────────────────────
