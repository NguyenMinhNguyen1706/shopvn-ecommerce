{
  "name": "ecommerce-backend",
  "version": "1.0.0",
  "description": "ShopVN production-oriented e-commerce REST API",
  "main": "index.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "worker": "node src/workers/background.worker.js",
    "test": "jest --verbose",
    "test:ci": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage",
    "test:watch": "jest --watch",
    "load:test": "node scripts/load-test.js",
    "db:backup": "node scripts/backup-db.js",
    "db:restore": "node scripts/restore-db.js",
    "db:migrate": "node scripts/migrate-with-lock.js",
    "db:migrate:direct": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "db:migrate:undo:all": "sequelize-cli db:migrate:undo:all",
    "db:migrate:status": "sequelize-cli db:migrate:status",
    "db:seed": "sequelize-cli db:seed:all",
    "db:seed:undo": "sequelize-cli db:seed:undo:all"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "axios": "^1.17.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.2",
    "bwip-js": "^4.11.1",
    "cloudinary": "^2.10.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.6.2",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "multer": "^2.1.1",
    "nodemailer": "^9.0.3",
    "pg": "^8.21.0",
    "pg-hstore": "^2.3.4",
    "qs": "^6.15.2",
    "redis": "^6.0.0",
    "sequelize": "^6.37.8",
    "sequelize-cli": "6.6.5",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.1.14"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/services/**/*.js"
    ]
  },
  "overrides": {
    "uuid": "11.1.1"
  }
}
